# Detectar si existe commit previo sin contaminar la variable con la salida del hash
if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
  BASE="HEAD~1"
else
  BASE="HEAD"
fi

node ./tools/run-nx-with-node-options.cjs affected --target=lint --base="$BASE"
node ./tools/run-nx-with-node-options.cjs affected --target=test --base="$BASE"
